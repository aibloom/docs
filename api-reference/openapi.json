    "/v1/uploads": {
      "post": {
        "tags": ["Uploads"],
        "summary": "Upload file",
        "description": "Upload an avatar image or voice sample. Supports multipart/form-data or JSON with a URL to fetch from. Automatically updates the persona's `avatar_url` or `voice_sample_url` field.",
        "operationId": "upload",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file", "category", "persona_id"],
                "properties": {
                  "file": { "type": "string", "format": "binary" },
                  "category": { "type": "string", "enum": ["avatar", "voice"] },
                  "persona_id": { "type": "string", "format": "uuid" }
                }
              }
            },
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["url", "category", "persona_id"],
                "properties": {
                  "url": { "type": "string", "description": "URL to fetch file from" },
                  "category": { "type": "string", "enum": ["avatar", "voice"] },
                  "persona_id": { "type": "string", "format": "uuid" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "File uploaded and processed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "key": { "type": "string", "description": "R2 storage key" },
                        "url": { "type": "string", "description": "Public URL" },
                        "category": { "type": "string", "enum": ["avatar", "voice"], "description": "Upload category" },
                        "persona_id": { "type": "string", "format": "uuid", "description": "Persona that was updated" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
